enum TestResultType {
    VITAMIN_D
}

enum VitaminDUnit {
    NG_ML
    NMOL_L
}

model TestResult {
    id String @id @default(uuid())
    patientId String
    type TestResultType
    value String
    valueNumber Float?
    unit VitaminDUnit?
    testedAt DateTime
    createdAt DateTime @default(now())
    testedById String?
    testedBy Clinic? @relation(fields: [testedById], references: [id])
    
    patient Patient @relation(fields: [patientId], references: [id])
    consentRequests ConsentRequest[]
    consents Consent[]
    vitaminDRecommendation VitaminDRecommendation?
}