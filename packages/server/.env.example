# Server
PORT=3003
NODE_ENV=development

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=health_platform
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Encryption & KMS
ENCRYPTION_KEY_ID=local-dev-key
KMS_REGION=eu-central-1
KMS_KEY_ID=arn:aws:kms:eu-central-1:ACCOUNT_ID:key/KEY_ID

# AWS (for production)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Email (for password resets, breach notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourcompany.de

# Compliance
DPO_EMAIL=dpo@yourcompany.de
COMPANY_NAME=Your Healthcare Company
DATA_RESIDENCY_COUNTRY=DE

# Logging
LOG_LEVEL=debug
AUDIT_LOG_RETENTION_DAYS=2555

# Security
CSRF_ENABLED=true
RATE_LIMIT_ENABLED=true
HELMET_ENABLED=true
