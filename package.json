{
  "name": "app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:dev --workspace=packages/server\" \"npm run dev --workspace=packages/web\" \"npm run dev --workspace=packages/web-dashboard\" \"npm run dev --workspace=packages/web-patient\"",
    "prepare": "husky",
    "lint": "npm run lint --workspaces --if-present",
    "lint:check": "npm run lint:check --workspaces --if-present",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.57.0"
  }
}
